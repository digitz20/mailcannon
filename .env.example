
# Environment variables for Next.js frontend and Express backend

# --- Next.js Specific ---
# URL of your Next.js app (used by backend for CORS)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:9002
# URL of your Express backend server (used by Next.js Server Actions)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001


# --- Express Backend Specific ---
# Port for the backend server
BACKEND_PORT=5001

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database_name>?retryWrites=true&w=majority
MONGODB_CREDENTIALS_COLLECTION=sender_credentials # Optional: Collection name for storing credentials

# Nodemailer Configuration (for sending emails)
# SMTP Host (e.g., smtp.gmail.com for Gmail, or your email provider's SMTP server)
NODEMAILER_HOST=smtp.example.com
# SMTP Port (e.g., 587 for TLS, 465 for SSL)
NODEMAILER_PORT=587
# SMTP User (your email address used for sending)
NODEMAILER_USER=user@example.com
# SMTP Password (your email password or app-specific password)
NODEMAILER_PASS=your_email_password

# Password for the sender's email, if you intend to save it with credentials.
# NOTE: Storing and using a single password from env vars for multiple senders' credentials
# or for the primary email sending account requires careful security consideration.
# The current implementation saves this password along with the 'senderEmail' from the form.
SENDER_PASSWORD=this_is_a_password_from_env_for_sender_email

# --- General ---
# NODE_ENV=development # or production
